<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-10">

    <div class="page-header mb-4">
      <h2 class="fw-bold text-primary">
        <i class="bi bi-calendar-x me-2"></i>הגשת אילוצים לסידור עבודה
      </h2>
      <p class="text-muted">בחר את שמך, לאחר מכן סמן את התאריכים / המשמרות שבהם אינך יכול לשרת</p>
    </div>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle me-2"></i><%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <i class="bi bi-exclamation-circle me-2"></i><%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <!-- Step 1: Select personnel -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-person-fill me-2"></i>שלב 1 - בחר את שמך</h5>
      </div>
      <div class="card-body">
        <% if (personnel.length === 0) { %>
        <div class="alert alert-warning mb-0">
          <i class="bi bi-info-circle me-2"></i>
          לא נמצאו אנשי צוות במערכת. המנהל צריך להוסיף אנשי צוות תחילה.
        </div>
        <% } else { %>
        <div class="row g-3 align-items-end">
          <div class="col-md-5">
            <label class="form-label fw-bold">שם / תפקיד</label>
            <select id="personnelSelect" class="form-select form-select-lg">
              <option value="">-- בחר שם --</option>
              <% const grouped = {}; %>
              <% personnel.forEach(p => { %>
                <% if (!grouped[p.role_name]) grouped[p.role_name] = []; %>
                <% grouped[p.role_name].push(p); %>
              <% }); %>
              <% Object.keys(grouped).sort().forEach(roleName => { %>
              <optgroup label="<%= roleName %>">
                <% grouped[roleName].forEach(p => { %>
                <option value="<%= p.id %>" data-role="<%= p.role_name %>"><%= p.name %></option>
                <% }); %>
              </optgroup>
              <% }); %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">חודש</label>
            <input type="month" id="monthPicker" class="form-control form-control-lg"
                   value="<%= new Date().toISOString().slice(0,7) %>">
          </div>
          <div class="col-md-4">
            <button id="loadConstraintsBtn" class="btn btn-primary btn-lg w-100" disabled>
              <i class="bi bi-calendar3 me-2"></i>טען לוח אילוצים
            </button>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Preferred Facility Selector (shown after name selection) -->
    <% if (facilities.length > 0) { %>
    <div id="preferredFacilityContainer" class="card shadow-sm mb-4 d-none border-info">
      <div class="card-header bg-info bg-opacity-10">
        <h6 class="mb-0 text-info"><i class="bi bi-building me-2"></i>מתקן מועדף לשיבוץ</h6>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3">
          בחר מתקן שבו תרצה לעבוד. האלגוריתם יעדיף לשבץ אותך לשם, אולם המנהל יכול לשנות.
        </p>
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label fw-bold">מתקן מועדף</label>
            <select id="preferredFacilitySelect" class="form-select">
              <option value="">-- ללא העדפה --</option>
              <% facilities.forEach(f => { %>
              <option value="<%= f.id %>"><%= f.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-md-3">
            <button id="saveFacilityPrefBtn" class="btn btn-outline-info">
              <i class="bi bi-floppy me-1"></i>שמור העדפה
            </button>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Step 2: Calendar constraint selector -->
    <div id="constraintSection" class="d-none">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-calendar-check me-2"></i>שלב 2 - סמן אילוצים</h5>
          <span id="selectedPersonnelBadge" class="badge bg-white text-success fs-6"></span>
        </div>
        <div class="card-body">
          <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            <strong>הוראות:</strong> לחץ על תאריך לסמן אי-זמינות ליום כולו, או בחר משמרת ספציפית.
            תאים מסומנים <span class="badge bg-danger">באדום</span> = אי-זמינות.
          </div>

          <!-- Shift legend -->
          <% if (shifts.length > 0) { %>
          <div class="mb-3">
            <strong>סוג אי-זמינות:</strong>
            <div class="btn-group ms-2" role="group" id="shiftTypeGroup">
              <input type="radio" class="btn-check" name="shiftType" id="shiftTypeAll" value="" checked>
              <label class="btn btn-outline-danger btn-sm" for="shiftTypeAll">יום שלם</label>
              <% shifts.forEach(s => { %>
              <input type="radio" class="btn-check" name="shiftType" id="shiftType<%= s.id %>" value="<%= s.id %>">
              <label class="btn btn-outline-warning btn-sm" for="shiftType<%= s.id %>">
                <%= s.name %>
                <% if (s.start_time) { %><small class="text-muted"> (<%= s.start_time %>–<%= s.end_time %>)</small><% } %>
              </label>
              <% }); %>
            </div>
          </div>
          <% } %>

          <!-- Calendar grid -->
          <div id="calendarGrid" class="calendar-grid mt-3"></div>

          <!-- Save button -->
          <div class="mt-3 d-flex gap-2">
            <button id="saveConstraintsBtn" class="btn btn-success">
              <i class="bi bi-floppy me-2"></i>שמור אילוצים
            </button>
            <button id="clearAllBtn" class="btn btn-outline-danger">
              <i class="bi bi-trash me-2"></i>נקה הכל
            </button>
          </div>
        </div>
      </div>

      <!-- Current constraints list -->
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0"><i class="bi bi-list-check me-2"></i>אילוצים קיימים</h6>
        </div>
        <div class="card-body p-0">
          <div id="constraintsList">
            <div class="text-center py-3 text-muted">טוען...</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
const SHIFTS = <%- JSON.stringify(shifts) %>;
const PERSONNEL = <%- JSON.stringify(personnel) %>;
const FACILITIES = <%- JSON.stringify(facilities) %>;
</script>
<script src="/js/constraints.js"></script>
<script>
// ===== Preferred Facility Feature =====
(function() {
  const facilitySelect = document.getElementById('personnelSelect');
  const facilityContainer = document.getElementById('preferredFacilityContainer');
  const facilityDropdown = document.getElementById('preferredFacilitySelect');
  const saveBtn = document.getElementById('saveFacilityPrefBtn');
  let currentPersonnelId = null;

  if (!facilityContainer || !facilityDropdown) return;

  facilitySelect.addEventListener('change', function() {
    currentPersonnelId = this.value;
    if (!currentPersonnelId) {
      facilityContainer.classList.add('d-none');
      return;
    }
    const person = PERSONNEL.find(p => String(p.id) === String(currentPersonnelId));
    if (!person) return;
    facilityDropdown.value = person.preferred_facility_id || '';
    facilityContainer.classList.remove('d-none');
    if (saveBtn) saveBtn.textContent = 'שמור העדפה';
  });

  if (saveBtn) {
    saveBtn.addEventListener('click', async function() {
      if (!currentPersonnelId) return;
      const facilityId = facilityDropdown.value || null;
      try {
        const r = await fetch(`/personnel/${currentPersonnelId}/preferred-facility`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ preferred_facility_id: facilityId })
        });
        const data = await r.json();
        if (data.success) {
          saveBtn.textContent = '✓ נשמר!';
          saveBtn.classList.add('btn-success');
          saveBtn.classList.remove('btn-outline-info');
          setTimeout(() => {
            saveBtn.textContent = 'שמור העדפה';
            saveBtn.classList.remove('btn-success');
            saveBtn.classList.add('btn-outline-info');
          }, 2500);
          // Update local cache
          const person = PERSONNEL.find(p => String(p.id) === String(currentPersonnelId));
          if (person) person.preferred_facility_id = facilityId ? parseInt(facilityId) : null;
        } else {
          alert('שגיאה: ' + data.error);
        }
      } catch(e) { alert('שגיאת רשת'); }
    });
  }
})();
</script>

<%- include('partials/footer') %>
