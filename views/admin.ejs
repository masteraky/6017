<script>
async function saveMaxShiftsRule() {
  const roleId = document.getElementById('msRoleId').value;
  const personnelId = document.getElementById('msPersonnelId').value;
  const maxShifts = document.getElementById('msMaxShifts').value;
  const periodType = document.getElementById('msPeriodType').value;

  if (!roleId && !personnelId) {
    alert('נא לבחור תפקיד או אדם ספציפי');
    return;
  }
  try {
    const r = await fetch('/api/max-shifts-rules', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ role_id: roleId||null, personnel_id: personnelId||null, max_shifts: maxShifts, period_type: periodType })
    });
    const data = await r.json();
    if (data.success) location.reload();
    else alert('שגיאה: ' + data.error);
  } catch(e) { alert('שגיאת רשת'); }
}

async function deleteMaxShiftsRule(id) {
  if (!confirm('למחוק חוק זה?')) return;
  try {
    const r = await fetch(`/api/max-shifts-rules/${id}`, {method:'DELETE'});
    const data = await r.json();
    if (data.success) location.reload();
    else alert('שגיאה: ' + data.error);
  } catch(e) { alert('שגיאת רשת'); }
}

async function saveRequirement() {
  const shiftId = document.getElementById('reqShiftId').value;
  const roleId = document.getElementById('reqRoleId').value;
  const count = document.getElementById('reqCount').value;
  try {
    const r = await fetch(`/admin/shifts/${shiftId}/requirements`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ role_id: roleId, count: count })
    });
    const data = await r.json();
    if (data.success) {
      location.reload();
    } else {
      alert('שגיאה: ' + data.error);
    }
  } catch(e) { alert('שגיאת רשת'); }
}

async function deleteRequirement(shiftId, roleId) {
  if (!confirm('למחוק דרישה זו?')) return;
  try {
    const r = await fetch(`/admin/shifts/${shiftId}/requirements/${roleId}/delete`, {method:'POST'});
    const data = await r.json();
    if (data.success) location.reload();
    else alert('שגיאה: ' + data.error);
  } catch(e) { alert('שגיאת רשת'); }
}

// Guide tab search (placeholder, no JS needed)

// ===== DELETE ROLE MODAL =====
document.querySelectorAll('.delete-role-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    showDeleteRoleModal(
      parseInt(btn.dataset.roleId),
      btn.dataset.roleName,
      parseInt(btn.dataset.personnelCount)
    );
  });
});

let _deleteRoleId = null;

function showDeleteRoleModal(roleId, roleName, personnelCount) {
  _deleteRoleId = roleId;
  document.getElementById('deleteRoleForm').action = `/admin/roles/${roleId}/delete`;
  document.getElementById('drPersonnelAction').value = '';
  document.getElementById('drNewRoleId').value = '';
  document.getElementById('drRoleInfo').textContent = `תפקיד: ${roleName}`;

  // hide/show options based on whether personnel exist
  const hasPersonnel = personnelCount > 0;
  document.getElementById('drNoPersonnel').classList.toggle('d-none', hasPersonnel);
  document.getElementById('drHasPersonnel').classList.toggle('d-none', !hasPersonnel);
  document.getElementById('drPersonnelCount').textContent = personnelCount;

  // remove the current role from the reassign dropdown
  document.querySelectorAll('#drTargetRole option').forEach(opt => {
    opt.hidden = opt.dataset.roleId == roleId;
  });

  // reset radio buttons
  document.querySelectorAll('input[name="drAction"]').forEach(r => r.checked = false);
  document.getElementById('drReassignSelect').classList.add('d-none');

  new bootstrap.Modal(document.getElementById('deleteRoleModal')).show();
}

// toggle reassign dropdown visibility
document.addEventListener('change', function(e) {
  if (e.target.name === 'drAction') {
    document.getElementById('drReassignSelect').classList.toggle('d-none', e.target.value !== 'reassign');
  }
});

function confirmDeleteRole() {
  const hasPersonnel = !document.getElementById('drHasPersonnel').classList.contains('d-none');

  if (hasPersonnel) {
    const action = document.querySelector('input[name="drAction"]:checked')?.value;
    if (!action) { alert('יש לבחור פעולה עבור אנשי הצוות המשויכים.'); return; }
    if (action === 'reassign') {
      const newRoleId = document.getElementById('drTargetRole').value;
      if (!newRoleId) { alert('יש לבחור תפקיד חלופי.'); return; }
      document.getElementById('drNewRoleId').value = newRoleId;
    }
    document.getElementById('drPersonnelAction').value = action;
  }

  document.getElementById('deleteRoleForm').submit();
}
</script>

