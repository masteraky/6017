          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p id="drRoleInfo" class="fw-semibold mb-3"></p>

          <!-- no personnel: simple confirm -->
          <div id="drNoPersonnel" class="d-none">
            <div class="alert alert-warning py-2">
              <i class="bi bi-exclamation-triangle me-1"></i>פעולה זו אינה הפיכה.
            </div>
          </div>

          <!-- has personnel: ask what to do -->
          <div id="drHasPersonnel" class="d-none">
            <div class="alert alert-warning py-2 mb-3 small">
              <i class="bi bi-people-fill me-1"></i>
              <span id="drPersonnelCount"></span> אנשי צוות משויכים לתפקיד זה. מה לעשות איתם?
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="drAction" id="drActionDelete" value="delete">
              <label class="form-check-label text-danger fw-semibold" for="drActionDelete">
                <i class="bi bi-person-x me-1"></i>מחק את כל אנשי הצוות המשויכים
              </label>
              <div class="text-muted small me-4">יימחקו גם האילוצים והשיבוצים שלהם</div>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="drAction" id="drActionReassign" value="reassign">
              <label class="form-check-label fw-semibold" for="drActionReassign">
                <i class="bi bi-arrow-left-right me-1"></i>שייך אותם לתפקיד אחר
              </label>
            </div>
            <div id="drReassignSelect" class="d-none me-4 mt-2">
              <select class="form-select form-select-sm" id="drTargetRole">
                <option value="">— בחר תפקיד —</option>
                <% roles.forEach(function(ro) { %>
                <option value="<%= ro.id %>" data-role-id="<%= ro.id %>"><%= ro.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ביטול</button>
          <button type="button" class="btn btn-danger" id="drConfirmBtn" onclick="confirmDeleteRole()">
            <i class="bi bi-trash me-1"></i>מחק תפקיד
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Personnel search filter
document.getElementById('personnelSearch')?.addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('#personnelTable tbody tr').forEach(tr => {
    tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>

<%- include('partials/footer') %>
