<%- include('partials/header') %>

<div class="row justify-content-center mt-5">
  <div class="col-md-5 col-lg-4">
    <div class="card shadow-lg">
      <div class="card-header bg-primary text-white text-center py-4">
        <i class="bi bi-shield-lock-fill fs-1 d-block mb-2"></i>
        <h4 class="mb-0">כניסת מנהל</h4>
        <small class="opacity-75">יחידה 6017</small>
      </div>
      <div class="card-body p-4">
        <% if (error) { %>
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-circle me-2"></i><%= error %>
        </div>
        <% } %>
        <form method="POST" action="/admin/login">
          <div class="mb-3">
            <label class="form-label fw-bold">סיסמת מנהל</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password" class="form-control form-control-lg"
                     placeholder="הכנס סיסמה" autofocus required>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 btn-lg">
            <i class="bi bi-box-arrow-in-left me-2"></i>כניסה
          </button>
        </form>
        <hr>
        <a href="/" class="btn btn-outline-secondary w-100">
          <i class="bi bi-arrow-right me-2"></i>חזרה לדף הגשת אילוצים
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
