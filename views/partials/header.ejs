<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/">
      <i class="bi bi-shield-fill-check me-2"></i>יחידה 6017
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/"><i class="bi bi-calendar-check me-1"></i>הגשת אילוצים</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/instructions"><i class="bi bi-book me-1"></i>הוראות שימוש</a>
        </li>
        <% if (locals.isAdminLoggedIn) { %>
        <li class="nav-item">
          <a class="nav-link" href="/admin"><i class="bi bi-gear me-1"></i>לוח בקרה</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/admin/logout"><i class="bi bi-box-arrow-left me-1"></i>יציאה</a>
        </li>
        <% } else { %>
        <li class="nav-item">
          <a class="nav-link" href="/admin/login"><i class="bi bi-lock me-1"></i>כניסת מנהל</a>
        </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<main class="container-fluid py-4">
